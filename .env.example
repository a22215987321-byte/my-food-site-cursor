# Firebase Web SDK (evonvchat-prod) — from Firebase Console → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=evonvchat-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=evonvchat-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=evonvchat-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Vercel server / cron) — from Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cron auth for /api/design-feed-run
CRON_SECRET=

# Optional: Gemini for AI design posts
GEMINI_API_KEY=
